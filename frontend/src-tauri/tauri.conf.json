{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MyBookshelfAI",
  "version": "0.1.0",
  "identifier": "com.mybookshelfai.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MyBookshelfAI",
        "label": "main",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "zoomHotkeysEnabled": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "externalBin": [
      "binaries/mybookshelf-backend"
    ],
    "icon": [
      "icons/icon.png"
    ]
  }
}
